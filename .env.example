# --- Database ---
# MongoDB Atlas connection string (mongodb+srv://...)
MONGODB_URI=

# --- News sources ---
# GNews free tier API key: https://gnews.io  (100 requests/day)
GNEWS_API_KEY=

# Comma-separated list of enabled source ids. Unset = all sources enabled.
# Available ids: gnews, hackernews
# Example: ENABLED_SOURCES=gnews,hackernews
ENABLED_SOURCES=

# --- OpenAI ---
OPENAI_API_KEY=
# Model used for the combined summary + sentiment call.
OPENAI_MODEL=gpt-4.1-nano
